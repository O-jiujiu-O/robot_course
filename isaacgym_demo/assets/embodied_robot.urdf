<?xml version="1.0"?>
<robot name="embodied_robot">
  <material name="blue"><color rgba="0.1 0.35 0.8 1"/></material>
  <material name="dark"><color rgba="0.12 0.12 0.14 1"/></material>
  <material name="orange"><color rgba="1.0 0.45 0.05 1"/></material>
  <material name="silver"><color rgba="0.65 0.68 0.72 1"/></material>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/><child link="base_link"/><origin xyz="0 0 0.20"/>
  </joint>
  <link name="base_link">
    <visual><geometry><box size="0.52 0.42 0.18"/></geometry><material name="blue"/></visual>
    <collision><geometry><box size="0.52 0.42 0.18"/></geometry></collision>
    <inertial><mass value="12"/><inertia ixx="0.2088" ixy="0" ixz="0" iyy="0.3028" iyz="0" izz="0.4468"/></inertial>
  </link>

  <link name="left_wheel_link">
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry><material name="dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry></collision>
    <inertial><origin rpy="1.5707963 0 0"/><mass value="0.8"/><inertia ixx="0.001755" ixy="0" ixz="0" iyy="0.001755" iyz="0" izz="0.00324"/></inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_wheel_link"/><origin xyz="0.18 0.22 -0.105"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0"/>
  </joint>

  <link name="right_wheel_link">
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry><material name="dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry></collision>
    <inertial><origin rpy="1.5707963 0 0"/><mass value="0.8"/><inertia ixx="0.001755" ixy="0" ixz="0" iyy="0.001755" iyz="0" izz="0.00324"/></inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_wheel_link"/><origin xyz="0.18 -0.22 -0.105"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0"/>
  </joint>

  <link name="left_rear_wheel_link">
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry><material name="dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry></collision>
    <inertial><origin rpy="1.5707963 0 0"/><mass value="0.8"/><inertia ixx="0.001755" ixy="0" ixz="0" iyy="0.001755" iyz="0" izz="0.00324"/></inertial>
  </link>
  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_rear_wheel_link"/><origin xyz="-0.18 0.22 -0.105"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0"/>
  </joint>

  <link name="right_rear_wheel_link">
    <visual><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry><material name="dark"/></visual>
    <collision><origin rpy="1.5707963 0 0"/><geometry><cylinder radius="0.09" length="0.045"/></geometry></collision>
    <inertial><origin rpy="1.5707963 0 0"/><mass value="0.8"/><inertia ixx="0.001755" ixy="0" ixz="0" iyy="0.001755" iyz="0" izz="0.00324"/></inertial>
  </link>
  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_rear_wheel_link"/><origin xyz="-0.18 -0.22 -0.105"/><axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0"/>
  </joint>

  <link name="arm_base_link">
    <visual><geometry><cylinder radius="0.10" length="0.08"/></geometry><material name="silver"/></visual>
    <collision><geometry><cylinder radius="0.10" length="0.08"/></geometry></collision>
    <inertial><mass value="1"/><inertia ixx="0.003033" ixy="0" ixz="0" iyy="0.003033" iyz="0" izz="0.005"/></inertial>
  </link>
  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/><child link="arm_base_link"/><origin xyz="0 0 0.13"/>
  </joint>

  <link name="arm_link_1">
    <visual><origin xyz="0 0 0.18"/><geometry><box size="0.07 0.07 0.36"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 0.18"/><geometry><box size="0.07 0.07 0.36"/></geometry></collision>
    <inertial><origin xyz="0 0 0.18"/><mass value="1.2"/><inertia ixx="0.01345" ixy="0" ixz="0" iyy="0.01345" iyz="0" izz="0.00098"/></inertial>
  </link>
  <joint name="arm_joint_1" type="revolute">
    <parent link="arm_base_link"/><child link="arm_link_1"/><origin xyz="0 0 0.04"/><axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="35" velocity="1.5"/><dynamics damping="0.8" friction="0.1"/>
  </joint>

  <link name="arm_link_2">
    <visual><origin xyz="0 0 0.15"/><geometry><box size="0.06 0.06 0.30"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 0.15"/><geometry><box size="0.06 0.06 0.30"/></geometry></collision>
    <inertial><origin xyz="0 0 0.15"/><mass value="0.8"/><inertia ixx="0.00624" ixy="0" ixz="0" iyy="0.00624" iyz="0" izz="0.00048"/></inertial>
  </link>
  <joint name="arm_joint_2" type="revolute">
    <parent link="arm_link_1"/><child link="arm_link_2"/><origin xyz="0 0 0.36"/><axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="25" velocity="1.8"/><dynamics damping="0.6" friction="0.08"/>
  </joint>

  <link name="tool_link">
    <visual name="gripper_palm_visual"><origin xyz="0 0 0.025"/><geometry><box size="0.10 0.16 0.05"/></geometry><material name="silver"/></visual>
    <visual name="left_finger_visual"><origin xyz="0 0.065 0.11"/><geometry><box size="0.04 0.03 0.14"/></geometry><material name="dark"/></visual>
    <visual name="right_finger_visual"><origin xyz="0 -0.065 0.11"/><geometry><box size="0.04 0.03 0.14"/></geometry><material name="dark"/></visual>
    <collision name="gripper_palm_collision"><origin xyz="0 0 0.025"/><geometry><box size="0.10 0.16 0.05"/></geometry></collision>
    <collision name="left_finger_collision"><origin xyz="0 0.065 0.11"/><geometry><box size="0.04 0.03 0.14"/></geometry></collision>
    <collision name="right_finger_collision"><origin xyz="0 -0.065 0.11"/><geometry><box size="0.04 0.03 0.14"/></geometry></collision>
    <inertial><origin xyz="0 0 0.07"/><mass value="0.35"/><inertia ixx="0.00120" ixy="0" ixz="0" iyy="0.00065" iyz="0" izz="0.00125"/></inertial>
  </link>
  <joint name="tool_joint" type="fixed">
    <parent link="arm_link_2"/><child link="tool_link"/><origin xyz="0 0 0.30"/>
  </joint>

  <link name="camera_link">
    <visual><geometry><box size="0.08 0.10 0.07"/></geometry><material name="dark"/></visual>
    <collision><geometry><box size="0.08 0.10 0.07"/></geometry></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.000282" ixy="0" ixz="0" iyy="0.000188" iyz="0" izz="0.000273"/></inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/><origin xyz="0.27 0 0.10"/>
  </joint>

  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/><child link="camera_optical_link"/>
    <origin xyz="0.045 0 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>
</robot>
